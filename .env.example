# ── LangGraph Server (container-level, owned by the platform) ──────────────
# Used by the standalone server; `langgraph dev` runs fully in-memory without these.
DATABASE_URI=postgresql://apex:apex@localhost:5432/apex
REDIS_URI=redis://localhost:6379
FF_V2_EVENT_STREAMING=false
HTTP_MAX_REQUEST_BODY_BYTES=27262976
CORS_CONFIG={"allow_origins":["http://localhost:5173","http://127.0.0.1:5173"],"allow_methods":["GET","POST","PUT","PATCH","DELETE","OPTIONS"],"allow_headers":["authorization","content-type","idempotency-key","last-event-id","x-api-key","x-request-id"],"allow_credentials":true,"expose_headers":["content-location","retry-after","x-pagination-next","x-pagination-total"],"max_age":600}
APEX_RATE_LIMIT__RUN_CREATE_REQUESTS=10
APEX_RATE_LIMIT__RUN_CREATE_WINDOW_S=60
# LANGGRAPH_CLOUD_LICENSE_KEY=   # required for the production standalone server (Enterprise)
# LANGSMITH_API_KEY=             # optional tracing

# ── APEX domain settings (pydantic-settings, APEX_ prefix, __ nesting) ─────
APEX_ENVIRONMENT=dev
APEX_DATABASE__URI=postgresql+asyncpg://apex:apex@localhost:5432/apex

# ── MinIO artifact store (dev object store, docker-compose.dev.yaml) ───────
# Secret key for the "minio-artifacts" connection
# (secret_ref env:APEX_INTEGRATION_MINIO_SECRET_KEY,
# seeded by scripts/seed_catalog.py). Matches MINIO_ROOT_PASSWORD in dev compose.
APEX_INTEGRATION_MINIO_SECRET_KEY=apex-minio

# ── docker-compose.yaml interpolation (full stack only) ────────────────────
# These are read by docker-compose.yaml via ${VAR:-default} (auto-loaded from
# this file). They keep credentials/license out of the compose file. The full
# stack reaches services by name (postgres/redis/minio), so the localhost URIs
# above are NOT used there.
# APEX_POSTGRES_PASSWORD=apex
# APEX_BOOTSTRAP_ADMIN_KEY=apex-local-admin-key  # x-api-key for the full stack
# APEX_AUTH__DEV_API_KEY=soak-dev-key            # required by compose-ha only
