# Dashboard dev-server environment (documentation template).
#
# NOTE: vite.config.ts reads this variable from the *shell* environment when
# the config is evaluated — Vite does NOT auto-load .env files into process.env
# at config time. Export it (or prefix the command) instead of relying on this
# file being picked up:
#
#   APEX_API_PROXY=http://127.0.0.1:2024 npm run -w @apex/dashboard dev

# Backend target for the dev proxy (/v1, /threads, /runs, /assistants, /ok).
# Default: http://127.0.0.1:2024 (local `langgraph dev` / `make dev`).
APEX_API_PROXY=http://127.0.0.1:2024

# Optional dashboard-only dev auth bypass. Put these in
# apps/dashboard/.env.development.local so Vite dev loads them while Vitest
# test mode does not. This bypass is also guarded by import.meta.env.DEV so
# production builds cannot use it.
# VITE_APEX_DEV_AUTH=true
# VITE_APEX_DEV_API_KEY=dev-key-local
